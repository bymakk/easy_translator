{
  "manifest_version": 3,
  "name": "Translator Popup",
  "version": "0.0.19",
  "version_name": "0.19",
  "description": "Перевод выделенного текста (публичный endpoint Google translate, без своего сервера)",
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
