{
  "manifest_version": 3,
  "name": "Translator Popup",
  "version": "0.0.89",
  "version_name": "0.89",
  "description": "Перевод выделенного текста на любой странице. Google, Yandex и AI-перевод.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://browser.translate.yandex.net/*",
    "https://ai.translate.obfsn.ru/*",
    "https://api.github.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
